  {
    "name": "guanlab_dengkw_pm",
    "label": "Guanlab-dengkw",
    "commit": "227295281678eca957eea4bf231e11a53ff91c27",
    "summary": "A kernel ridge regression method with RBF kernel.",
    "description": "This is a solution developed by Team Guanlab - dengkw in the Neurips 2021 competition to predict one modality\nfrom another using kernel ridge regression (KRR) with RBF kernel. Truncated SVD is applied on the combined\ntraining and test data from modality 1 followed by row-wise z-score normalization on the reduced matrix. The\ntruncated SVD of modality 2 is predicted by training a KRR model on the normalized training matrix of modality 1.\nPredictions on the normalized test matrix are then re-mapped to the modality 2 feature space via the right\nsingular vectors.",
    "type": "method",
    "link_code": "https://github.com/openproblems-bio/task_predict_modality",
    "link_documentation": "https://github.com/openproblems-bio/neurips2021_multimodal_topmethods/tree/main/src/predict_modality/methods/Guanlab-dengkw",
    "link_implementation": "https://github.com/openproblems-bio/task_predict_modality/blob/227295281678eca957eea4bf231e11a53ff91c27/src/methods/guanlab_dengkw_pm",
    "link_container_image": "https://ghcr.io/openproblems-bio/task_predict_modality/methods/guanlab_dengkw_pm:build_main",
    "authors": [],
    "references": {
      "doi": ["10.1101/2022.04.11.487796"],
      "bibtex": []
    },
    "additional_info": {
      "preferred_normalization": "log_cp10k",
      "repository_url": "https://github.com/openproblems-bio/neurips2021_multimodal_topmethods/tree/main/src/predict_modality/methods/Guanlab-dengkw",
      "competition_submission_id": 170636
