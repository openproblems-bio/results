  {
    "name": "cellmapper_scvi",
    "label": "CellMapper+scVI",
    "commit": "227295281678eca957eea4bf231e11a53ff91c27",
    "summary": "Modality prediction in an scVI latent space using CellMapper",
    "description": "CellMapper is a general framework for k-NN based mapping tasks in single-cell and spatial genomics.\nThis variant uses CellMapper to project modalities from a reference dataset (train) onto a query dataset \n(test) in a modality-specific latent space computed with suitable scvi-tools models. For gene expression data, \nwe use the scVI model on raw counts (nb likelihood), for ADT data, we use the scVI models on normalized counts \n(gaussian likelihood), and for ATAC data, we use the PeakVI model on raw counts. The actual CellMapper pipeline is \nmodality-agnostic.",
    "type": "method",
    "link_code": "https://github.com/quadbio/cellmapper",
    "link_documentation": "https://cellmapper.readthedocs.io/en/latest/",
    "link_implementation": "https://github.com/openproblems-bio/task_predict_modality/blob/227295281678eca957eea4bf231e11a53ff91c27/src/methods/cellmapper_scvi",
    "link_container_image": "https://ghcr.io/openproblems-bio/task_predict_modality/methods/cellmapper_scvi:build_main",
    "authors": [],
    "references": {
      "doi": ["10.5281/zenodo.15683594"],
      "bibtex": []
    },
    "additional_info": {
      "preferred_normalization": "log_cp10k",
      "variants": {
        "cellmapper_hnoca_hvg": {
          "kernel_method": "hnoca",
          "use_hvg": true,
          "adt_normalization": "clr"
        },
        "cellmapper_hnoca_all_genes": {
          "kernel_method": "hnoca",
          "use_hvg": false,
          "adt_normalization": "clr"
        },
        "cellmapper_gauss_hvg": {
          "kernel_method": "gauss",
          "use_hvg": true,
          "adt_normalization": "clr"
        },
        "cellmapper_gauss_hvg_log_cp10k": {
          "kernel_method": "gauss",
          "use_hvg": true,
          "adt_normalization": "log_cp10k"
        },
        "cellmapper_gauss_all_genes": {
          "kernel_method": "gauss",
          "use_hvg": false,
          "adt_normalization": "clr"
        }
      }
    },
    "version": "build_main"
  },
